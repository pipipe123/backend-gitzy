# Entorno: production | development
ENVIRONMENT=production

# GitHub Token (requerido para búsquedas)
GITHUB_TOKEN=

# GitLab Token (opcional)
GITLAB_TOKEN=

# Azure DevOps Token (opcional)
AZURE_TOKEN=

# Secret Key para firmar cookies (generar con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Orígenes permitidos para CORS (separados por coma)
# Ejemplo: https://gitzy.app,https://www.gitzy.app
ALLOWED_ORIGINS=
